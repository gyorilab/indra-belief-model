{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://indra-belief.local/schemas/indra_pair_comparison_card_v1.schema.json",
	"title": "INDRA paired architecture comparison card",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"schema_version",
		"generated_at",
		"pair_id",
		"pair_href",
		"status",
		"not_defined_reason",
		"workflow_status",
		"guardrails",
		"runs",
		"overlap",
		"comparable",
		"resource_frontier",
		"denominator_ledger",
		"architecture_native"
	],
	"properties": {
		"schema_version": { "const": "indra_pair_comparison_card_v1" },
		"generated_at": {
			"type": "string",
			"pattern": "^\\d{4}-\\d{2}-\\d{2}T"
		},
		"pair_id": { "type": "string", "minLength": 1 },
		"pair_href": { "type": "string", "minLength": 1 },
		"status": { "enum": ["defined", "not_defined"] },
		"not_defined_reason": { "$ref": "#/$defs/nullableString" },
		"workflow_status": { "$ref": "#/$defs/nullableString" },
		"guardrails": {
			"type": "array",
			"minItems": 1,
			"items": { "type": "string", "minLength": 1 }
		},
		"runs": {
			"type": "object",
			"additionalProperties": false,
			"required": ["monolithic", "decomposed"],
			"properties": {
				"monolithic": { "$ref": "#/$defs/run" },
				"decomposed": { "$ref": "#/$defs/run" }
			}
		},
		"overlap": {
			"anyOf": [
				{ "type": "null" },
				{ "$ref": "#/$defs/overlap" }
			]
		},
		"comparable": {
			"anyOf": [
				{ "type": "null" },
				{ "$ref": "#/$defs/comparable" }
			]
		},
		"resource_frontier": {
			"anyOf": [
				{ "type": "null" },
				{ "$ref": "#/$defs/resourceFrontier" }
			]
		},
		"denominator_ledger": {
			"type": "array",
			"items": { "$ref": "#/$defs/denominatorRow" }
		},
		"architecture_native": {
			"type": "object",
			"additionalProperties": false,
			"required": ["monolithic_tiers", "decomposed_probes"],
			"properties": {
				"monolithic_tiers": {
					"type": "array",
					"items": { "$ref": "#/$defs/monolithicTier" }
				},
				"decomposed_probes": {
					"type": "array",
					"items": { "$ref": "#/$defs/decomposedProbe" }
				}
			}
		}
	},
	"$defs": {
		"nullableString": {
			"anyOf": [
				{ "type": "string" },
				{ "type": "null" }
			]
		},
		"nullableNumber": {
			"anyOf": [
				{ "type": "number" },
				{ "type": "null" }
			]
		},
		"nullableInteger": {
			"anyOf": [
				{ "type": "integer" },
				{ "type": "null" }
			]
		},
		"run": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"present",
				"run_id",
				"architecture",
				"status",
				"model_id_default",
				"started_at",
				"finished_at",
				"n_evidences",
				"cost_estimate_usd",
				"cost_actual_usd",
				"duration_s"
			],
			"properties": {
				"present": { "type": "boolean" },
				"run_id": { "$ref": "#/$defs/nullableString" },
				"architecture": { "enum": ["monolithic", "decomposed"] },
				"status": { "$ref": "#/$defs/nullableString" },
				"model_id_default": { "$ref": "#/$defs/nullableString" },
				"started_at": { "$ref": "#/$defs/nullableString" },
				"finished_at": { "$ref": "#/$defs/nullableString" },
				"n_evidences": { "$ref": "#/$defs/nullableInteger" },
				"cost_estimate_usd": { "$ref": "#/$defs/nullableNumber" },
				"cost_actual_usd": { "$ref": "#/$defs/nullableNumber" },
				"duration_s": { "$ref": "#/$defs/nullableNumber" }
			}
		},
		"overlap": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"monolithic_evidences",
				"decomposed_evidences",
				"monolithic_comparable_evidences",
				"decomposed_comparable_evidences",
				"overlap_evidences",
				"overlap_statements",
				"monolithic_only_evidences",
				"decomposed_only_evidences",
				"monolithic_true_nonoverlap_evidences",
				"decomposed_true_nonoverlap_evidences",
				"monolithic_overlap_pct",
				"decomposed_overlap_pct",
				"monolithic_step_error_evidences",
				"decomposed_step_error_evidences",
				"monolithic_nonaggregate_step_error_evidences",
				"decomposed_nonaggregate_step_error_evidences",
				"monolithic_missing_aggregate_evidences",
				"decomposed_missing_aggregate_evidences",
				"monolithic_nonverdict_aggregate_evidences",
				"decomposed_nonverdict_aggregate_evidences"
			],
			"properties": {
				"monolithic_evidences": { "type": "integer" },
				"decomposed_evidences": { "type": "integer" },
				"monolithic_comparable_evidences": { "type": "integer" },
				"decomposed_comparable_evidences": { "type": "integer" },
				"overlap_evidences": { "type": "integer" },
				"overlap_statements": { "type": "integer" },
				"monolithic_only_evidences": { "type": "integer" },
				"decomposed_only_evidences": { "type": "integer" },
				"monolithic_true_nonoverlap_evidences": { "type": "integer" },
				"decomposed_true_nonoverlap_evidences": { "type": "integer" },
				"monolithic_overlap_pct": { "$ref": "#/$defs/nullableNumber" },
				"decomposed_overlap_pct": { "$ref": "#/$defs/nullableNumber" },
				"monolithic_step_error_evidences": { "type": "integer" },
				"decomposed_step_error_evidences": { "type": "integer" },
				"monolithic_nonaggregate_step_error_evidences": { "type": "integer" },
				"decomposed_nonaggregate_step_error_evidences": { "type": "integer" },
				"monolithic_missing_aggregate_evidences": { "type": "integer" },
				"decomposed_missing_aggregate_evidences": { "type": "integer" },
				"monolithic_nonverdict_aggregate_evidences": { "type": "integer" },
				"decomposed_nonverdict_aggregate_evidences": { "type": "integer" }
			}
		},
		"comparable": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"n_overlap",
				"n_truth_overlap",
				"verdict_agreement_n",
				"verdict_agreement_rate",
				"both_correct_n",
				"monolithic_only_correct_n",
				"decomposed_only_correct_n",
				"both_incorrect_n",
				"verdict_label_pairs",
				"monolithic_score_mean",
				"decomposed_score_mean",
				"monolithic_mae",
				"decomposed_mae",
				"monolithic_bias",
				"decomposed_bias",
				"mean_score_delta",
				"monolithic_latency_mean_ms",
				"decomposed_latency_mean_ms",
				"monolithic_latency_observed_n",
				"decomposed_latency_observed_n",
				"monolithic_tokens_total",
				"decomposed_tokens_total",
				"monolithic_tokens_observed_n",
				"decomposed_tokens_observed_n"
			],
			"properties": {
				"n_overlap": { "type": "integer" },
				"n_truth_overlap": { "type": "integer" },
				"verdict_agreement_n": { "type": "integer" },
				"verdict_agreement_rate": { "$ref": "#/$defs/nullableNumber" },
				"both_correct_n": { "type": "integer" },
				"monolithic_only_correct_n": { "type": "integer" },
				"decomposed_only_correct_n": { "type": "integer" },
				"both_incorrect_n": { "type": "integer" },
				"verdict_label_pairs": {
					"type": "array",
					"items": { "$ref": "#/$defs/verdictPair" }
				},
				"monolithic_score_mean": { "$ref": "#/$defs/nullableNumber" },
				"decomposed_score_mean": { "$ref": "#/$defs/nullableNumber" },
				"monolithic_mae": { "$ref": "#/$defs/nullableNumber" },
				"decomposed_mae": { "$ref": "#/$defs/nullableNumber" },
				"monolithic_bias": { "$ref": "#/$defs/nullableNumber" },
				"decomposed_bias": { "$ref": "#/$defs/nullableNumber" },
				"mean_score_delta": { "$ref": "#/$defs/nullableNumber" },
				"monolithic_latency_mean_ms": { "$ref": "#/$defs/nullableNumber" },
				"decomposed_latency_mean_ms": { "$ref": "#/$defs/nullableNumber" },
				"monolithic_latency_observed_n": { "type": "integer" },
				"decomposed_latency_observed_n": { "type": "integer" },
				"monolithic_tokens_total": { "type": "integer" },
				"decomposed_tokens_total": { "type": "integer" },
				"monolithic_tokens_observed_n": { "type": "integer" },
				"decomposed_tokens_observed_n": { "type": "integer" }
			}
		},
		"verdictPair": {
			"type": "object",
			"additionalProperties": false,
			"required": ["monolithic_verdict", "decomposed_verdict", "support_cell", "n"],
			"properties": {
				"monolithic_verdict": { "type": "string" },
				"decomposed_verdict": { "type": "string" },
				"support_cell": {
					"enum": ["both_supported", "monolithic_only", "decomposed_only", "neither_supported"]
				},
				"n": { "type": "integer" }
			}
		},
		"resourceFrontier": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"monolithic",
				"decomposed",
				"spend_scope",
				"latency_scope",
				"quality_scope",
				"not_defined_reason"
			],
			"properties": {
				"monolithic": { "$ref": "#/$defs/resourceFrontierArch" },
				"decomposed": { "$ref": "#/$defs/resourceFrontierArch" },
				"spend_scope": { "type": "string" },
				"latency_scope": { "type": "string" },
				"quality_scope": { "type": "string" },
				"not_defined_reason": { "$ref": "#/$defs/nullableString" }
			}
		},
		"resourceFrontierArch": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"architecture",
				"run_id",
				"run_cost_usd",
				"run_cost_basis",
				"n_evidences",
				"cost_per_evidence_usd",
				"duration_s",
				"wall_seconds_per_evidence",
				"clean_overlap_n",
				"clean_overlap_latency_mean_ms",
				"clean_overlap_latency_observed_n",
				"clean_overlap_tokens_total",
				"clean_overlap_tokens_observed_n",
				"clean_overlap_tokens_per_observed_evidence",
				"truth_overlap_n",
				"mae"
			],
			"properties": {
				"architecture": { "enum": ["monolithic", "decomposed"] },
				"run_id": { "type": "string" },
				"run_cost_usd": { "$ref": "#/$defs/nullableNumber" },
				"run_cost_basis": { "enum": ["actual", "estimate", "missing"] },
				"n_evidences": { "type": "integer" },
				"cost_per_evidence_usd": { "$ref": "#/$defs/nullableNumber" },
				"duration_s": { "$ref": "#/$defs/nullableNumber" },
				"wall_seconds_per_evidence": { "$ref": "#/$defs/nullableNumber" },
				"clean_overlap_n": { "type": "integer" },
				"clean_overlap_latency_mean_ms": { "$ref": "#/$defs/nullableNumber" },
				"clean_overlap_latency_observed_n": { "type": "integer" },
				"clean_overlap_tokens_total": { "type": "integer" },
				"clean_overlap_tokens_observed_n": { "type": "integer" },
				"clean_overlap_tokens_per_observed_evidence": { "$ref": "#/$defs/nullableNumber" },
				"truth_overlap_n": { "type": "integer" },
				"mae": { "$ref": "#/$defs/nullableNumber" }
			}
		},
		"denominatorRow": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"key",
				"panel",
				"applicability",
				"metric_kind",
				"ledger_role",
				"parent_key",
				"unit",
				"denominator_n",
				"monolithic_n",
				"decomposed_n",
				"overlap_n",
				"excluded_n",
				"reason"
			],
			"properties": {
				"key": { "type": "string" },
				"panel": { "type": "string" },
				"applicability": {
					"enum": ["arch_blind", "arch_conditioned", "paired_only", "not_defined"]
				},
				"metric_kind": {
					"enum": [
						"denominator_base",
						"arch_arch_exact_label",
						"arch_arch_support_recode",
						"arch_arch_score_posture",
						"arch_arch_resource",
						"arch_indra_residual",
						"integrity_gate",
						"paired_nonoverlap",
						"architecture_native",
						"architecture_native_trace_health"
					]
				},
				"ledger_role": { "enum": ["root", "base", "metric", "gate", "native"] },
				"parent_key": { "$ref": "#/$defs/nullableString" },
				"unit": { "type": "string" },
				"denominator_n": { "$ref": "#/$defs/nullableInteger" },
				"monolithic_n": { "$ref": "#/$defs/nullableInteger" },
				"decomposed_n": { "$ref": "#/$defs/nullableInteger" },
				"overlap_n": { "$ref": "#/$defs/nullableInteger" },
				"excluded_n": { "$ref": "#/$defs/nullableInteger" },
				"reason": { "type": "string" }
			}
		},
		"monolithicTier": {
			"type": "object",
			"additionalProperties": false,
			"required": ["tier", "n", "mean_score"],
			"properties": {
				"tier": { "type": "string" },
				"n": { "type": "integer" },
				"mean_score": { "$ref": "#/$defs/nullableNumber" }
			}
		},
		"decomposedProbe": {
			"type": "object",
			"additionalProperties": false,
			"required": ["name", "n", "substrate_n", "error_n"],
			"properties": {
				"name": { "type": "string" },
				"n": { "type": "integer" },
				"substrate_n": { "type": "integer" },
				"error_n": { "type": "integer" }
			}
		}
	}
}
